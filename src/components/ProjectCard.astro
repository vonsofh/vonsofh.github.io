---
interface Props {
  title: string;
  summary: string;
  titleEn?: string;
  summaryEn?: string;
  stack?: string[];
  domain?: string;
  image?: string;
  slug: string;
}

const { title, summary, titleEn, summaryEn, stack = [], domain, image, slug } = Astro.props;
const domainLabel = domain ? new URL(domain).hostname.replace(/^www\./, '') : null;
---

<article class="group overflow-hidden rounded-xl border border-border dark:border-slate-700 bg-white dark:bg-slate-800 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5">
  <a href={`/projects/${slug}`} class="block">
    {image && (
      <div class="aspect-video overflow-hidden bg-surface dark:bg-slate-700">
        <img
          src={image}
          alt={title}
          class="h-full w-full object-cover transition-transform group-hover:scale-105"
          loading="lazy"
        />
      </div>
    )}
    <div class="p-5">
      <h3 class="text-lg font-semibold text-text dark:text-slate-200 group-hover:text-primary transition-colors">
        <span data-i18n-id>{title}</span>
        {titleEn && <span data-i18n-en>{titleEn}</span>}
      </h3>
      <p class="mt-2 text-sm text-text-muted dark:text-slate-400 line-clamp-2">
        <span data-i18n-id>{summary}</span>
        {summaryEn && <span data-i18n-en>{summaryEn}</span>}
      </p>
      {stack.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {stack.map((tech) => (
            <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
              {tech}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
  {domain && domainLabel && (
    <div class="flex items-center justify-between gap-3 border-t border-border/70 px-5 py-3 dark:border-slate-700/80">
      <div class="min-w-0">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-text-muted dark:text-slate-500">
          <span data-i18n-id>Domain Produksi</span>
          <span data-i18n-en>Production Domain</span>
        </p>
        <p class="truncate text-sm font-medium text-text dark:text-slate-200">{domainLabel}</p>
      </div>
      <a
        href={domain}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex shrink-0 items-center rounded-lg border border-primary/25 px-3 py-1.5 text-xs font-semibold text-primary transition-colors hover:border-primary hover:bg-primary/5"
      >
        <span data-i18n-id>Buka Situs</span>
        <span data-i18n-en>Open Site</span>
      </a>
    </div>
  )}
</article>
