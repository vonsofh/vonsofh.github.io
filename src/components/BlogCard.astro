---
interface Props {
  title: string;
  description: string;
  titleEn?: string;
  descriptionEn?: string;
  publishedAt: Date;
  tags?: string[];
  slug: string;
}

const { title, description, titleEn, descriptionEn, publishedAt, tags = [], slug } = Astro.props;

const dateId = publishedAt.toLocaleDateString('id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const dateEn = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group block rounded-xl border border-border dark:border-slate-700 bg-white dark:bg-slate-800 p-5 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5"
>
  <time class="text-xs font-medium text-text-muted dark:text-slate-400">
    <span data-i18n-id>{dateId}</span>
    <span data-i18n-en>{dateEn}</span>
  </time>
  <h3 class="mt-2 text-lg font-semibold text-text dark:text-slate-200 group-hover:text-primary transition-colors">
    <span data-i18n-id>{title}</span>
    {titleEn && <span data-i18n-en>{titleEn}</span>}
  </h3>
  <p class="mt-2 text-sm text-text-muted dark:text-slate-400 line-clamp-2">
    <span data-i18n-id>{description}</span>
    {descriptionEn && <span data-i18n-en>{descriptionEn}</span>}
  </p>
  {tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
