---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title={`Contact — ${site.title}`} description="Get in touch with me. Send a message or reach out on social media.">
  <section class="mx-auto max-w-5xl px-6 py-16 md:py-24">
    <div class="animate-fade-in-up">
      <h1 class="text-3xl font-extrabold tracking-tight text-text dark:text-white sm:text-4xl">
        <span data-i18n-id>Kontak</span><span data-i18n-en>Contact</span>
      </h1>
      <p class="mt-3 text-text-muted dark:text-slate-400">
        <span data-i18n-id>Punya pertanyaan, ide proyek, atau hanya ingin menyapa? Hubungi di bawah.</span>
        <span data-i18n-en>Have a question, project idea, or just want to say hello? Reach out below.</span>
      </p>
    </div>

    <div class="mt-10 grid gap-10 md:grid-cols-2 scroll-reveal">
      <!-- Contact Form -->
      <form
        action={site.formspreeEndpoint}
        method="POST"
        class="space-y-5"
      >
        <!-- Honeypot (anti-spam) -->
        <input type="text" name="_gotcha" style="display:none" />

        <div>
          <label for="name" class="block text-sm font-medium text-text dark:text-slate-200">
            <span data-i18n-id>Nama</span><span data-i18n-en>Name</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="mt-1 w-full rounded-lg border border-border dark:border-slate-600 bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-text dark:text-slate-200 placeholder:text-text-muted dark:placeholder:text-slate-500 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none transition-colors"
            placeholder="John Doe"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-text dark:text-slate-200">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="mt-1 w-full rounded-lg border border-border dark:border-slate-600 bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-text dark:text-slate-200 placeholder:text-text-muted dark:placeholder:text-slate-500 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none transition-colors"
            placeholder="johndoe@email.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-text dark:text-slate-200">
            <span data-i18n-id>Pesan</span><span data-i18n-en>Message</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="mt-1 w-full rounded-lg border border-border dark:border-slate-600 bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-text dark:text-slate-200 placeholder:text-text-muted dark:placeholder:text-slate-500 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none transition-colors resize-y"
            placeholder="Tulis pesan Anda di sini..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-primary-dark focus:ring-2 focus:ring-primary/20 focus:outline-none"
        >
          <span data-i18n-id>Kirim Pesan</span><span data-i18n-en>Send Message</span>
        </button>
      </form>

      <!-- Contact Info -->
      <div class="space-y-6">
        <div>
          <h2 class="text-lg font-semibold text-text dark:text-slate-200">
            <span data-i18n-id>Cara Lain Menghubungi Saya</span><span data-i18n-en>Other Ways to Reach Me</span>
          </h2>
          <p class="mt-2 text-sm text-text-muted dark:text-slate-400">
            <span data-i18n-id>Lebih suka chat cepat? Silakan hubungi via WhatsApp atau LinkedIn.</span>
            <span data-i18n-en>Prefer a quick chat? Feel free to reach out via WhatsApp or LinkedIn.</span>
          </p>
        </div>

        <div class="space-y-4">
          {site.social.whatsapp && (
            <a
              href={site.social.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 rounded-xl border border-border dark:border-slate-700 bg-white dark:bg-slate-800 p-4 transition-all hover:shadow-md hover:-translate-y-0.5"
            >
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-100 dark:bg-green-900/30">
                <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-text dark:text-slate-200">WhatsApp</p>
                <p class="text-xs text-text-muted dark:text-slate-400">
                  <span data-i18n-id>Chat cepat via WhatsApp</span><span data-i18n-en>Quick chat via WhatsApp</span>
                </p>
              </div>
            </a>
          )}

          {site.social.linkedin && (
            <a
              href={site.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 rounded-xl border border-border dark:border-slate-700 bg-white dark:bg-slate-800 p-4 transition-all hover:shadow-md hover:-translate-y-0.5"
            >
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-900/30">
                <svg class="h-5 w-5 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-text dark:text-slate-200">LinkedIn</p>
                <p class="text-xs text-text-muted dark:text-slate-400">
                  <span data-i18n-id>Terhubung secara profesional</span><span data-i18n-en>Connect professionally</span>
                </p>
              </div>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
