---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import site from '../../data/site.json';
import { getCollection } from 'astro:content';
import { isEnVariant, baseSlug } from '../../content.config';

const allEntries = await getCollection('blog');
const enMap = new Map(
  allEntries.filter((p) => isEnVariant(p.id) && !p.data.draft).map((p) => [baseSlug(p.id), p])
);
const allPosts = allEntries
  .filter((p) => !isEnVariant(p.id) && !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout title={`Blog — ${site.title}`} description="Articles, tutorials, and thoughts on web development.">
  <section class="mx-auto max-w-5xl px-6 py-16 md:py-24">
    <div class="animate-fade-in-up">
      <h1 class="text-3xl font-extrabold tracking-tight text-text dark:text-white sm:text-4xl">Blog</h1>
      <p class="mt-3 text-text-muted dark:text-slate-400">
        <span data-i18n-id>Artikel, tutorial, dan pemikiran tentang pengembangan web.</span>
        <span data-i18n-en>Articles, tutorials, and thoughts on web development.</span>
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {allPosts.map((post, i) => {
        const en = enMap.get(post.id);
        return (
          <div class="scroll-reveal" style={`transition-delay: ${i * 0.1}s`}>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              titleEn={en?.data.title}
              descriptionEn={en?.data.description}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              slug={post.id}
            />
          </div>
        );
      })}
    </div>

    {allPosts.length === 0 && (
      <p class="mt-10 text-center text-text-muted dark:text-slate-400">
        <span data-i18n-id>Belum ada tulisan blog. Nantikan segera!</span>
        <span data-i18n-en>No blog posts yet. Check back soon!</span>
      </p>
    )}
  </section>
</BaseLayout>
