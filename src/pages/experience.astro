---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import experience from '../data/experience.json';
import site from '../data/site.json';
---

<BaseLayout title={`Experience — ${site.title}`} description="My professional work history and experience.">
  <section class="mx-auto max-w-5xl px-6 py-16 md:py-24">
    <div class="animate-fade-in-up">
      <h1 class="text-3xl font-extrabold tracking-tight text-text dark:text-white sm:text-4xl">
        <span data-i18n-id>Pengalaman</span><span data-i18n-en>Experience</span>
      </h1>
      <p class="mt-3 text-text-muted dark:text-slate-400">
        <span data-i18n-id>Perjalanan profesional saya — peran, tanggung jawab, dan dampak yang saya buat.</span>
        <span data-i18n-en>My professional journey — roles, responsibilities, and the impact I've made.</span>
      </p>
    </div>

    <div class="mt-10 scroll-reveal">
      {experience.map((job) => (
        <ExperienceItem
          company={job.company}
          role={job.role}
          period={job.period}
          description={job.description}
          stack={job.stack}
        />
      ))}
    </div>

    {experience.length === 0 && (
      <p class="mt-10 text-center text-text-muted dark:text-slate-400">
        <span data-i18n-id>Bagian pengalaman segera hadir.</span>
        <span data-i18n-en>Experience section coming soon.</span>
      </p>
    )}
  </section>
</BaseLayout>
